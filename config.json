{
  "design_resolution": [1920, 1080],
  "dry_run_default": true,
  "default_max_runs": 30,
  "screenshot": {
    "retries": 3,
    "retry_delay_seconds": 1.0,
    "screencapture_timeout_seconds": 20
  },
  "notifications": {
    "enabled": true,
    "desktop": true,
    "sound": true,
    "sound_file": "/System/Library/Sounds/Glass.aiff"
  },
  "safety": {
    "min_free_disk_gb": 7,
    "max_swap_used_gb": 10,
    "cleanup_screenshots": true,
    "keep_latest_screenshots": 400,
    "max_screenshot_age_days": 3,
    "keep_latest_error_screenshots": 100,
    "max_error_screenshot_age_days": 14
  },
  "screenshot_storage": {
    "preferred_base_dir": "/Volumes/File/douyin_shop_ai_video_auto_artifacts",
    "fallback_to_local": true
  },
  "performance": {
    "wait_text_poll_seconds": 2.5,
    "material_ready_poll_seconds": 3.0
  },
  "app": {
    "activate_before_run": false,
    "name": "抖店工作台",
    "settle_seconds": 1.0,
    "quit_after_success": true
  },
  "refresh": {
    "enabled": true,
    "before_each_run": true,
    "on_error": true,
    "max_error_refresh_retries": 1,
    "anchor_texts": ["巨量千川"],
    "top_nav_region": [0, 45, 900, 70],
    "offset_from_anchor": [-328, 0],
    "fallback_point": [73, 98],
    "allow_coordinate_fallback": true,
    "after_refresh_wait_seconds": 2.0
  },
  "pre_run_manual_switch_seconds": 3,
  "prefer_coordinate_fallback": false,
  "ocr_disabled_waits": {
    "default": 2.0,
    "product_modal": 3.0,
    "video_type_area": 5.0,
    "result_task": 8.0
  },
  "ocr": {
    "enabled": true,
    "primary": "paddle",
    "fallbacks": ["vision"],
    "paddle": {
      "worker_enabled": true,
      "worker_recycle_runs": 3,
      "worker_timeout_seconds": 90,
      "lang": "ch",
      "use_angle_cls": true,
      "det_limit_side_len": 1600
    }
  },
  "allow_coordinate_fallback": true,
  "click_backend": "pyautogui",
  "move_duration_seconds": 0.15,
  "after_click_delay_seconds": 0.8,
  "timeouts": {
    "modal_seconds": 12,
    "type_area_seconds": 45,
    "result_seconds": 25,
    "quota_seconds": 8
  },
  "waits": {
    "after_select_product_confirm_seconds": 2.0,
    "after_video_type_select_seconds": 10.0,
    "after_generate_click_seconds": 4.0,
    "between_runs_seconds": 2.0
  },
  "regions": {
    "left_panel": [225, 300, 390, 760],
    "product_modal": [1260, 120, 640, 950],
    "result_panel": [625, 300, 1280, 760],
    "quota": [245, 965, 360, 45]
  },
  "readiness": {
    "after_video_type_texts": ["选择图片素材", "立即生成", "今天还可"],
    "generate_button_enabled_check": true,
    "generate_button_region": [248, 1005, 340, 42],
    "enabled_blue_min": 130,
    "enabled_red_max": 135,
    "material_ready_timeout_seconds": 90,
    "loading_texts": ["正在检测", "优化图片", "适合创作"]
  },
  "targets": {
